class Solution:
    def letterCombinations(self, digits: str) -> List[str]:
        map = ["", "", "abc", "def", "ghi", "jkl", "mno", "pqrs", "tuv", "wxyz"]
        def helper(digits,ans,index,current):
            if index==len(digits):
                ans.append(current)
                return

            s=map[int(digits[index])]
            for char in s:
                helper(digits,ans,index+1,current+char)


        ans=[]
        helper(digits,ans,0,"")
        return ans
