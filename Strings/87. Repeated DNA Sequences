class Solution:
    def findRepeatedDnaSequences(self, s: str) -> List[str]:
        res=set()
        n=len(s)
        st=set()

        for i in range(n-10+1):
            if s[i:i+10] in st:
                res.add(s[i:i+10])
            else:
                st.add(s[i:i+10])

        return list(res)
