class Solution:
    def letterCombinations(self, digits: str) -> List[str]:
        h={
            '2':'abc',
            '3':'def',
            '4':'ghi',
            '5':'jkl',
            '6':'mno',
            '7':'pqrs',
            '8':'tuv',
            '9':'wxyz'
        }   
        
        res=['']
        for d in digits:
            newarr=[]
            for a in res:
                for ne in h[d]:
                    e=a+ne
                    newarr.append(e)

            res=newarr

        return res
