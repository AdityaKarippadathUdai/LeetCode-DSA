class Solution:
    def getSum(self, nums: List[int]) -> int:
        n=len(nums)
        pre=[0]*(n+1)

        for i in range(n):
            pre[i+1]=pre[i]+nums[i]

        res=max(nums)

        a1=[0]*n
        x=0
        y=-1

        for i in range(n):
            k=1 if i>y else min(a1[x+y-i],y-i+1)

            while i-k>=0 and i+k<n and nums[i-k]==nums[i+k]:
                k+=1

            a1[i]=k
            if i+k-1>y:
                x=i-k+1
                y=i+k-1

            left=i-a1[i]+1
            right=i+a1[i]-1

            res=max(res,pre[right+1]-pre[left])

        a2=[0]*n
        x=0
        y=-1

        for i in range(n):
            k=0 if i>y else  min(a2[x+y-i+1],y-i+1)
            while i-k-1>=0 and i+k<n and nums[i-k-1]==nums[i+k]:
                k+=1

            a2[i]=k
            if i+k-1>y:
                x=i-k
                y=i+k-1

            if a2[i]:
                left=i-a2[i]
                right=i+a2[i]-1
                res=max(res,pre[right+1]-pre[left])

        return res
