class Solution:
    def maxActiveSectionsAfterTrade(self, s: str) -> int:
        ones = s.count('1')
        t = '1' + s + '1'
        chars = []
        lens = []
        i = 0
        while i < len(t):
            j = i
            while j < len(t) and t[j] == t[i]:
                j += 1
            chars.append(t[i])
            lens.append(j - i)
            i = j
        best = 0
        for i in range(1, len(chars) - 1):
            if chars[i] == '1' and chars[i - 1] == '0' and chars[i + 1] == '0':
                best = max(best, lens[i - 1] + lens[i + 1])
        return ones + best
