class Solution:
    def numberOfBeams(self, bank: List[str]) -> int:
        res=0
        prev=0
        n=len(bank)
        m=len(bank[0])
        for i in range(m):
            if bank[0][i]=='1':
                prev+=1

        for i in range(1,n):
            curr=0
            row=bank[i]
            curr=row.count('1')

            res+=prev*curr
            if curr!=0:
                prev=curr

        return res
