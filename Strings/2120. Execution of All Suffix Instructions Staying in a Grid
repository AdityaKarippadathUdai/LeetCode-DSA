class Solution:
    def executeInstructions(self, n: int, startPos: List[int], s: str) -> List[int]:
        res=[]
        ns=len(s)
        for r in range(ns):
            i=startPos[0]
            j=startPos[1]
            steps=0
            for d in range(r,ns):
                if s[d]=='U':
                    i-=1
                elif s[d]=='D':
                    i+=1
                elif s[d]=='L':
                    j-=1
                elif s[d]=='R':
                    j+=1
                if i>=n or j>=n or i<0 or j<0:
                    break
                steps+=1

            res.append(steps)

        return res
