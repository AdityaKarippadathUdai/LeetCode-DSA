class Solution:
    def canMakeSubsequence(self, s: str, t: str) -> bool:
        n=len(s)
        m=len(t)

        pre=[-1]*n

        j=0
        for i in range(n):
            while j<m and s[i]!=t[j]:
                j+=1
            if j==m:
                break
            pre[i]=j
            j+=1


        if pre[-1]!=-1:
            return True

        sfx=[-1]*n
        j=m-1
        for i in range(n-1,-1,-1):
            while j>=0 and s[i]!=t[j]:
                j-=1
            if j<0:
                break

            sfx[i]=j
            j-=1

        for i in range(n):

            b=-1 if i==0 else pre[i-1]
            a=m if i==n-1 else sfx[i+1]

            if b==-1 and i>0:
                continue
            if a==-1 and i<n-1:
                continue

            if a-b>1:
                return True

        return False
                
