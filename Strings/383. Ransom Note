class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        
        a=defaultdict(int)
        b=defaultdict(int)

        for  ch in ransomNote:
            a[ch]+=1

        for ch in magazine:
            b[ch]+=1

        for ch,val in a.items():
            if a[ch]>b[ch]:
                return False

        return True
