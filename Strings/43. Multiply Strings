class Solution:
    def multiply(self, num1: str, num2: str) -> str:
        n=len(num1)
        m=len(num2)
        res=0
        for i in range(n-1,-1,-1):
            carry=0
            a=0
            p=1
            for j in range(m-1,-1,-1):
                prod=int(num1[i])*int(num2[j])+carry
                d=prod%10
                carry=prod//10
                a+=d*p
                p=p*10
            a+=carry*p

            res+=a*(10**(n-i-1))

        return str(res)
            
