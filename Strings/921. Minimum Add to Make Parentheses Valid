class Solution:
    def minAddToMakeValid(self, s: str) -> int:
        if not s:
            return 0

        res=0
        cnt=0
        n=len(s)
        for i in range(n):
            if cnt==0 and s[i]==')':
                res+=1
            elif s[i]=='(':
                cnt+=1
            else:
                cnt-=1

        res+=cnt
        return res
