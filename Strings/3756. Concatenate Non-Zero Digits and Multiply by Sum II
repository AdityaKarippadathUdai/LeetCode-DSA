from bisect import bisect_left, bisect_right
from typing import List

class Solution:
    def sumAndMultiply(self, s: str, queries: List[List[int]]) -> List[int]:
        MOD = 10**9 + 7

        pos = []
        digits = []

        for i, ch in enumerate(s):
            if ch != '0':
                pos.append(i)
                digits.append(int(ch))

        m = len(digits)

        digitPre = [0] * (m + 1)
        for i in range(m):
            digitPre[i + 1] = digitPre[i] + digits[i]

        p10 = [1] * (m + 1)
        for i in range(1, m + 1):
            p10[i] = (p10[i - 1] * 10) % MOD

        prev = [0] * (m + 1)
        for i in range(m):
            prev[i + 1] = (prev[i] * 10 + digits[i]) % MOD

        res = []

        for l, r in queries:
            L = bisect_left(pos, l)
            R = bisect_right(pos, r) - 1

            if L > R:
                res.append(0)
                continue

            k = R - L + 1
            ds = digitPre[R + 1] - digitPre[L]
            x = (prev[R + 1] - prev[L] * p10[k]) % MOD
            res.append((x * ds) % MOD)

        return res
