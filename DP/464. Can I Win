from functools import lru_cache
class Solution:
    def canIWin(self, maxChoosableInteger: int, desiredTotal: int) -> bool:
        mxc=maxChoosableInteger
        dt=desiredTotal


        if dt==0:
            return True

        total=mxc*(mxc+1)//2

        if total<dt:
            return False

        @lru_cache(None)
        def dfs(mask,remain):
            for i in range(1,mxc+1):
                bit=1<<(i-1)
                if bit&mask:
                    continue

                if i>=remain:
                    return True

                if not dfs(mask|bit,remain-i):
                    return True

            return False

        return dfs(0,dt)

        
