from functools import lru_cache
class Solution:
    def diffWaysToCompute(self, expression: str) -> List[int]:
        
        @lru_cache(None)
        def solve(expr):
            res=[]

            for i,ch in enumerate(expr):
                if ch in "+-*":
                    r=solve(expr[i+1:])
                    l=solve(expr[:i])

                    for a in l:
                        for b in r:
                            if ch=="+":
                                res.append(a+b)
                            elif ch=="-":
                                res.append(a-b)
                            else:
                                res.append(a*b)

            if not res:
                res.append(int(expr))

            return res

        return solve(expression)
