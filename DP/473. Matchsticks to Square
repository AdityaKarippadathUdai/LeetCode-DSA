class Solution:
    def makesquare(self, matchsticks: List[int]) -> bool:
        n=len(matchsticks)
        total=sum(matchsticks)
        if total%4!=0:
            return False

        side=total//4
        sides=[0]*4
        matchsticks.sort(reverse=True)
        if matchsticks[0]>side:
            return False
        def dfs(ind):
            if ind==n:
                return True

            for i in range(4):
                if sides[i]+matchsticks[ind]>side:
                    continue

                sides[i]+=matchsticks[ind]
                if dfs(ind+1):
                    return True

                sides[i]-=matchsticks[ind]
            return False

        return dfs(0)
            
