from functools import lru_cache
class Solution:
    def combinationSum4(self, nums: List[int], target: int) -> int:

        @lru_cache(None)
        def util(curr):
            if curr==target:
                return 1
            
            if curr>target:
                return 0

            res=0
            for num in nums:
                if num+curr>target:
                    continue
                res+=util(curr+num)
            return res

        return util(0)
