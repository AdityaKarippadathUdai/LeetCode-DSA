# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def deleteMiddle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if head is None or head.next is None:
            return None

        sptr=head
        fptr=head
        hptr=ListNode(-1)
        hptr.next=head
        prev=hptr
        while fptr and fptr.next:
            sptr=sptr.next
            fptr=fptr.next.next
            prev=prev.next

        nxt=sptr.next
        prev.next=nxt
        sptr.next=None
        return hptr.next
