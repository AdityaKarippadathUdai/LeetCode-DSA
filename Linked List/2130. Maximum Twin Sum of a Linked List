# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def pairSum(self, head: Optional[ListNode]) -> int:
        sptr=head
        fptr=head
        if head is None:
            return 0
        if head.next.next is None:
            return head.val+head.next.val
        while fptr and fptr.next:
            fptr=fptr.next.next
            sptr=sptr.next

        def reverse(node):
            prev=None
            ptr=node
            while ptr:
                nxt=ptr.next
                ptr.next=prev
                prev=ptr
                ptr=nxt
            return prev

        ptr2=reverse(sptr)
        ptr1=head
        res=0
        while ptr1 and ptr2:
            res=max(res,ptr1.val+ptr2.val)
            ptr1=ptr1.next
            ptr2=ptr2.next

        return res
