class Solution:
    def minimumCost(self, cost1: int, cost2: int, costBoth: int, need1: int, need2: int) -> int:
        if cost1+cost2<=costBoth:
            return cost1*need1+cost2*need2

        res=0
        if need1>need2:
            res+=costBoth*need2
            need1-=need2
            need2=0
            if costBoth<cost1:
                res+=need1*costBoth
            else:
                res+=need1*cost1
        else:
            res+=costBoth*need1
            need2-=need1
            if costBoth<cost2:
                res+=need2*costBoth
            else:
                res+=need2*cost2

        return res
