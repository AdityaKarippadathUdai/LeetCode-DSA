class Solution:
    def minSteps(self, n: int) -> int:
        if n==1:
            return 0
        if n==2:
            return 2
        def isprime(n):
            m=int(n**0.5)
            for i in range(2,m+1):
                if n%i==0:
                    return False

            return True

        if isprime(n):
            return n

        def primefactor(n):
            p=[]
            f=2
            while f*f<=n:
                while n%f==0:
                    p.append(f)
                    n//=f
                f+=1

            if n>=2:
                p.append(n)
            return p

        return sum(primefactor(n))
