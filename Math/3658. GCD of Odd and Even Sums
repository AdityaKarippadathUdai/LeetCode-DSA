class Solution:
    def gcdOfOddEvenSums(self, n: int) -> int:
        evensum=0
        oddsum=0
        for i in range(1,n+1):
            evensum+=2*i
            oddsum+=2*i-1

        def gcd(num1,num2):
            while num1%num2!=0:
                a=num1%num2
                num1=num2
                num2=a
            return num2

        return gcd(evensum,oddsum)
