from collections import deque
import heapq
class Solution:
    def maximumSafenessFactor(self, grid: List[List[int]]) -> int:
        n=len(grid)
        if grid[0][0]==1 or grid[n-1][n-1]==1:
            return 0

        q=deque()
        dis=[[-1]*n for _ in range(n)]

        for i in range(n):
            for j in range(n):
                if grid[i][j]==1:
                    dis[i][j]=0
                    q.append((i,j))

        dir=[(1,0),(0,1),(-1,0),(0,-1)] 

        while q:
            x,y=q.popleft()
            for dx,dy in dir:
                nx=x+dx
                ny=y+dy 

                if 0<=nx<n and 0<=ny<n and dis[nx][ny]==-1:
                    dis[nx][ny]=dis[x][y]+1
                    q.append((nx,ny))


        b=[[-1]*n for _ in range(n)]
        pq=[(-dis[0][0],0,0)]
        b[0][0]=dis[0][0]

        while pq:
            s,x,y=heapq.heappop(pq)
            s=-s

            if (x,y)==(n-1,n-1):
                return s

            if s<b[x][y]:
                continue

            for dx,dy in dir:
                nx=x+dx
                ny=y+dy

                if 0<=nx<n and 0<=ny<n:
                    ns=min(s,dis[nx][ny])
                    if ns>b[nx][ny]:
                        b[nx][ny]=ns
                        heapq.heappush(pq,(-ns,nx,ny))
        
