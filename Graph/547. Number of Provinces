        vis=[0]*n
        from collections import deque
        q=deque()
        for i in range(n):
            if vis[i]:
                continue
            q.append(i)
            vis[i]=1
            cnt+=1
            while q:
                size=len(q)
                for _ in range(size):
                    node=q.popleft()
                    for j in range(n):
                        if isConnected[node][j]==1 and not vis[j]:
                            vis[j]=1
                            q.append(j)
        return cnt


