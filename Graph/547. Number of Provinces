class Solution:
    def findCircleNum(self, isConnected: List[List[int]]) -> int:
        seen=set()
        res=0
        adj=defaultdict(list)
        n=len(isConnected)

        for i in range(n):
            for j in range(n):
                a=i+1
                b=j+1
                c=isConnected[i][j]
                if c==1:
                    adj[a].append(b)
                    adj[b].append(a)
        for i in range(1,n+1):
            if i not in seen:
                res+=1
                q=deque()
                q.append(i)
                while q:
                    node=q.popleft()
                    if node in seen:
                        continue
                    seen.add(node)
                    for j in adj[node]:
                        q.append(j)

        return res
            




