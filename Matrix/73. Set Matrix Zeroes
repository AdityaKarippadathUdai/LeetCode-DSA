class Solution:
    def setZeroes(self, matrix: List[List[int]]) -> None:
        """
        Do not return anything, modify matrix in-place instead.
        """
        cols=set()
        rows=set()

        n=len(matrix)
        m=len(matrix[0])
        for i in range(n):
            for j in range(m):
                if matrix[i][j]==0:
                    cols.add(j)
                    rows.add(i)

        for i in rows:
            for j in range(m):
                matrix[i][j]=0

        for j in cols:
            for i in range(n):
                matrix[i][j]=0

