from collections import deque
class Solution:
    def findSafeWalk(self, grid: List[List[int]], health: int) -> bool:
        m=len(grid)
        n=len(grid[0])

        b=[[-1]*n for _ in range(m)]
        curr=health-grid[0][0]
        q=deque()
        q.append([0,0,curr])

        dir=[(0,1),(1,0),(-1,0),(0,-1)]
        while q:
            x,y,hp=q.popleft()
            if x==m-1 and y==n-1:
                return True

            for dx,dy in dir:
                nx=x+dx
                ny=y+dy
                if 0<=nx<m and 0<=ny<n:
                    nhp=hp
                    if grid[nx][ny]==1:
                        nhp=hp-1
                    if nhp>=1 and b[nx][ny]<nhp:
                        b[nx][ny]=nhp
                        q.append([nx,ny,nhp])

        return False

