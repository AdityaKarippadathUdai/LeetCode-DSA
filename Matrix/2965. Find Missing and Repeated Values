class Solution:
    def findMissingAndRepeatedValues(self, grid: List[List[int]]) -> List[int]:
        n=len(grid)
        st=set()
        res=[]
        for i in range(n):
            for j in range(n):
                if grid[i][j] in st:
                    res.append(grid[i][j])
                st.add(grid[i][j])

        for i in range(1,n*n+1):
            if i not in st:
                res.append(i)

        return res
