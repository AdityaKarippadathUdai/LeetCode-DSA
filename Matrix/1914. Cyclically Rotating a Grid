class Solution:
    def rotateGrid(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m=len(grid)
        n=len(grid[0])
        layers=min(m,n)//2

        for l in range(layers):
            arr=[]
            top=l
            left=l
            a=m-l-1
            b=n-l-1

            for j in range(left,b+1):
                arr.append(grid[top][j])

            for i in range(top+1,a):
                arr.append(grid[i][b])

            for j in range(b,left-1,-1):
                arr.append(grid[a][j])

            for i in range(a-1,top,-1):
                arr.append(grid[i][left])


            lenarr=len(arr)
            rot=k%lenarr
            rotated=arr[rot:] + arr[:rot]

            idx=0

            for j in range(left,b+1):
                grid[top][j]=rotated[idx]
                idx+=1

            for i in range(top+1,a):
                grid[i][b]=rotated[idx]
                idx+=1

            for j in range(b,left-1,-1):
                grid[a][j]=rotated[idx]
                idx+=1

            for i in range(a-1,top,-1):
                grid[i][left]=rotated[idx]
                idx+=1

            
        return grid
