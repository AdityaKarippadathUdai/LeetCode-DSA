class Solution:
    def search(self, nums: List[int], target: int) -> int:
        n=len(nums)
        i=0
        j=n-1
        while i<=j:
            mid=(i+j)//2
            if nums[mid]==target:
                return mid
            elif nums[i]<=nums[mid]:
                if nums[i]<=target<nums[mid]:
                    j=mid
                else:
                    i=mid+1
            else:
                if nums[mid]<target<=nums[j]:
                    i=mid+1
                else:
                    j=mid

        return -1
