class Solution:
    def sortByBits(self, arr: List[int]) -> List[int]:
        def countbit(x):
            cnt=0
            while x:
                if x&1:
                    cnt+=1
                x=x>>1
            return cnt

        h={}
        for num in arr:
            h[num]=countbit(num)
        
        arr.sort(key=lambda x:(h[x],x))
        return arr
