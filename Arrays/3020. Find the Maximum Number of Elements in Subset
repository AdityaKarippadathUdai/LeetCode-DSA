class Solution:
    def maximumLength(self, nums: List[int]) -> int:
        nums.sort()
        maxi=nums[-1]
        h=defaultdict(int)
        n=len(nums)
        for i in range(n):
            h[nums[i]]+=1

        res=1
        for i in range(n):

            a=nums[i]
            if h[a]<2:
                continue
            cnt=2
            if a==1:
                continue
            while a<=maxi:
                a=a**2
                if a not in h:
                    res=max(res,cnt-1)
                    break
                if h[a]<2:
                    res=max(res,cnt+1)
                    break
                cnt+=2
        if 1 in h:
            cnt=h[1]
            if cnt%2==0:
                res=max(res,cnt-1)
            else:
                res=max(res,cnt)
        return res
