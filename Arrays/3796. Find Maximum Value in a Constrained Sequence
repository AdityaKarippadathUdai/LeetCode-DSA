class Solution:
    def findMaxVal(self, n: int, restrictions: List[List[int]], diff: List[int]) -> int:
        pre=[0]*n
        for i in range(1,n):
            pre[i]=pre[i-1]+diff[i-1]

        restrictions.append([0,0])
        restrictions.append([n-1,10**18])
        restrictions.sort()

        m=len(restrictions)

        for i in range(1,m):
            ind1,h1=restrictions[i-1]
            ind2,h2=restrictions[i]

            dis=pre[ind2]-pre[ind1]
            restrictions[i][1]=min(h2,h1+dis)

        for i in range(m-2,-1,-1):
            ind1,h1=restrictions[i+1]
            ind2,h2=restrictions[i]
            dis=pre[ind1]-pre[ind2]
            restrictions[i][1]=min(h2,h1+dis)

        res=0
        for i in range(m-1):
            ind1,h1=restrictions[i]
            ind2,h2=restrictions[i+1]

            r=pre[ind2]-pre[ind1]

            tar=(h2+r-h1)/2

            idx=bisect_left(pre,pre[ind1]+tar,ind1,ind2+1)

            for j in (idx - 1,idx):
                if ind1<=j<=ind2:
                    t=pre[j]-pre[ind1]
                    p=min(h1+t,h2+(r-t))
                    res=max(res,p)

        return res
