class Cashier:

    def __init__(self, n: int, discount: int, products: List[int], prices: List[int]):
        self.n=n
        self.discount=discount
        self.products=products
        self.prices=prices
        self.i=0
        self.d={}
        for a,b in zip(products,prices):
            self.d[a]=b

    def getBill(self, product: List[int], amount: List[int]) -> float:
        self.i+=1
        bill=0
        for prod,q in zip(product,amount):
            price=self.d[prod]*q
            bill+=price
        if self.i==self.n:
            self.i=0
            bill=bill*((100-self.discount)/100)

        return bill




