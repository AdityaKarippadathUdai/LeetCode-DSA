class Solution:
    def maximumElementAfterDecrementingAndRearranging(self, arr: List[int]) -> int:
        n=len(arr)
        def isvalid(nums):
            for i in range(1,n):
                if abs(nums[i]-nums[i-1])>1:
                    return False

            return True
        
        if isvalid(arr) and arr[0]==1:
            return max(arr)

        arr.sort()

        if isvalid(arr) and arr[0]==1:
            return max(arr)

        if arr[0]!=1:
            arr[0]=1

        for i in range(1,n):
            if abs(arr[i]-arr[i-1])>1:
                arr[i]=arr[i-1]+1
        return arr[-1]
        
