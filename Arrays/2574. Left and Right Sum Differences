class Solution:
    def leftRightDifference(self, nums: List[int]) -> List[int]:
        n=len(nums)
        res=[0]*n
        total=sum(nums)
        lsum=0
        rsum=total
        for i in range(n):
            rsum-=nums[i]
            res[i]=abs(rsum-lsum)
            lsum+=nums[i]

        return res
