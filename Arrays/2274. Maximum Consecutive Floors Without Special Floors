class Solution:
    def maxConsecutive(self, bottom: int, top: int, special: List[int]) -> int:
        special.sort()
        if not special:
            return top-bottom+1
        res=0
        p=special[0]-bottom
        res=max(res,p)
        n=len(special)
        for i in range(1,n):
            p=special[i]-special[i-1]-1
            res=max(res,p)
        p=top-special[-1]
        res=max(res,p)

        return res
