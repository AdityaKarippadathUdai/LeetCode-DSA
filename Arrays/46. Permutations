class Solution:
    def permute(self, nums: List[int]) -> List[List[int]]:
        res=[]

        def util(a):
            if len(a)==len(nums):
                res.append(a[:])
                return a

            for n in nums:
                if n in a:
                    continue

                a.append(n)
                util(a)
                a.pop()

        util([])
        return res
