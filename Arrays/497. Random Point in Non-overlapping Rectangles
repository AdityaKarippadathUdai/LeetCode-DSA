import bisect
class Solution:

    def __init__(self, rects: List[List[int]]):
        self.rects=rects
        self.pre=[]
        total=0
        for a,b,x,y in rects:
            total+=(x-a+1)*(y-b+1)
            self.pre.append(total)
        self.total=total

    def pick(self) -> List[int]:
        r=random.randint(1,self.total)
        rec=bisect_left(self.pre,r)
        a,b,x,y=self.rects[rec]
        prev=0 if rec==0 else self.pre[rec-1]
        o=r-prev-1
        width=x-a+1

        return [a+(o%width),b+(o//width)]


