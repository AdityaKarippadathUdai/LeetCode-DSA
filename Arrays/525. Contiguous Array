class Solution:
    def findMaxLength(self, nums: List[int]) -> int:
        d={}
        n=len(nums)

        for i in range(n):
            if nums[i]==0:
                nums[i]=-1

        res=0
        curr=0
        for i in range(n):
            curr+=nums[i]
            if curr==0:
                res=max(res,i+1)

            elif curr in d:
                res=max(i-d[curr],res)
            else:
                d[curr]=i

        return res
