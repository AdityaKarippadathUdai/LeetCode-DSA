class Solution:
    def sortArray(self, nums: List[int]) -> List[int]:
        def merge(nums,left,mid,right):
            n=mid-left+1
            m=right-mid

            L=[0]*n
            R=[0]*m
            for i in range(n):
                L[i]=nums[left+i]
            for i in range(m):
                R[i]=nums[mid+i+1]

            i=0
            j=0
            k=left

            while i<n and j<m:
                if L[i]<R[j]:
                    nums[k]=L[i]
                    k+=1
                    i+=1
                else:
                    nums[k]=R[j]
                    k+=1
                    j+=1
            
            while i<n:
                nums[k]=L[i]
                k+=1
                i+=1
            
            while j<m:
                nums[k]=R[j]
                k+=1
                j+=1

        def mergesort(nums,left,right):
            if left<right:
                mid=(left+right)//2
                mergesort(nums,left,mid)
                mergesort(nums,mid+1,right)
                merge(nums,left,mid,right)

        n=len(nums)
        mergesort(nums,0,n-1)
        return nums

