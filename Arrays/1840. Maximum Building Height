class Solution:
    def maxBuilding(self, n: int, restrictions: List[List[int]]) -> int:
        restrictions.append([1,0])
        restrictions.sort()

        if restrictions[-1][0]!=n:
            restrictions.append([n,n-1])

        m=len(restrictions)
        for i in range(1,m):
            dis=restrictions[i][0]-restrictions[i-1][0]

            restrictions[i][1]=min(restrictions[i][1],restrictions[i-1][1]+dis)

        for i in range(m-2,-1,-1):
            dis=restrictions[i+1][0]-restrictions[i][0]

            restrictions[i][1]=min(restrictions[i][1],restrictions[i+1][1]+dis)

        res=0
        for i in range(1,m):
            dis=restrictions[i][0]-restrictions[i-1][0]
            h1=restrictions[i][1]
            h2=restrictions[i-1][1]

            mh=(h1+h2+dis)//2
            res=max(res,mh)


        return res
