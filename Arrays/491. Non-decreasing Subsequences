class Solution:
    def findSubsequences(self, nums: List[int]) -> List[List[int]]:
        res=[]
        n=len(nums)
        def util(curr,ind):
            nonlocal res
            if ind==n:
                if curr not in res and len(curr)>=2:
                    res.append(curr[:])
                return
            
            if not curr or curr[-1]<=nums[ind]:
                curr.append(nums[ind])
                util(curr,ind+1)
                curr.pop()
            util(curr,ind+1)

        util([],0)
        res.sort()
        return res
