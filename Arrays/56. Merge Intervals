class Solution:
    def merge(self, intervals: List[List[int]]) -> List[List[int]]:
        intervals.sort()
        res=[]
        res.append(intervals[0])
        n=len(intervals)
        for i in range(1,n):
            if intervals[i][0]<=res[-1][1] and intervals[i][0]>=res[-1][0]:
                res[-1][1]=max(res[-1][1],intervals[i][1])
            else:
                res.append(intervals[i])
        
        return res
