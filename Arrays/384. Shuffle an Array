from itertools import permutations
import random
class Solution:


    def __init__(self, nums: List[int]):
        self.org = nums[:]      
        self.nums = nums[:]     

    def reset(self) -> List[int]:
        self.nums = self.org[:]     
        return self.nums

    def shuffle(self) -> List[int]:
        arr = self.nums[:]          
        n = len(arr)

        for i in range(n):
            j = random.randint(i, n - 1)
            arr[i], arr[j] = arr[j], arr[i]

        self.nums = arr
        return arr


