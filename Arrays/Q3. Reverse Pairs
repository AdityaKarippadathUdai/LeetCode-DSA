class Solution:
    def reversePairs(self, nums: List[int]) -> int:
        def mergesort(left,right):
            if left>=right:
                return 0

            mid=(left+right)//2

            count=mergesort(left,mid)
            count+=mergesort(mid+1,right)

            j=mid+1
            for i in range(left,mid+1):
                while j<=right and nums[i]>2*nums[j]:
                    j+=1
                count+=j-(mid+1)

            arr=[]
            i=left
            j=mid+1

            while i<=mid and j<=right:
                if nums[i]>nums[j]:
                    arr.append(nums[j])
                    j+=1
                else:
                    arr.append(nums[i])
                    i+=1

            while i<=mid:
                arr.append(nums[i])
                i+=1

            while j<=right:
                arr.append(nums[j])
                j+=1

            nums[left:right+1]=arr
            return count

        n=len(nums)
        return mergesort(0,n-1) 
