class Solution {
public:
    int threeSumClosest(vector<int>& nums, int target) {
    sort(nums.begin(), nums.end());
    int n = nums.size();
    int d = INT_MAX;
    int res = 0;

    for (int i = 0; i < n - 1; i++) {
        if (i > 0 && nums[i] == nums[i - 1]) continue;

        int l = i + 1;
        int r = n - 1;

        while (l < r) {
            int sum = nums[i] + nums[l] + nums[r];
            int diff = abs(target - sum);

            if (diff < d) {
                d = diff;
                res = sum;
            }

            if (sum > target) {
                r--;
            } else {
                l++;
            }
        }
    }
    return res;        
    }
};
