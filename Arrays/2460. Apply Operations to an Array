class Solution:
    def applyOperations(self, nums: List[int]) -> List[int]:
        n=len(nums)
        for i in range(n-1):
            if nums[i]==nums[i+1]:
                nums[i]=2*nums[i]
                nums[i+1]=0

        z=-1
        i=0
        while i<n:
            if nums[i]!=0 and z!=-1:
                nums[i],nums[z]=nums[z],nums[i]
                z+=1
                i+=1
            elif nums[i]==0 and z==-1:
                z=i
                i+=1
            else:
                i+=1
        return nums
