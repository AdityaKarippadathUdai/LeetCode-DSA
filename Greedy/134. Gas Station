class Solution:
    def canCompleteCircuit(self, gas: List[int], cost: List[int]) -> int:
        n=len(gas)
        currgas=0
        res=0
        total=0
        for i in range(n):
            total+=gas[i]-cost[i]
            currgas+=gas[i]-cost[i]

            if currgas<0:
                currgas=0
                res=i+1

        if total<0:
            return -1
        
        return res
        
        
                
