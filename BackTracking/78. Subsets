class Solution:
    def subsets(self, nums: List[int]) -> List[List[int]]:
        res=[]
        def util(ind,nums,n,arr):
            if ind==n:
                res.append(arr)
                return
            util(ind+1,nums,n,arr[:])
            arr.append(nums[ind])
            util(ind+1,nums,n,arr[:])

        util(0,nums,len(nums),[])
        return res
