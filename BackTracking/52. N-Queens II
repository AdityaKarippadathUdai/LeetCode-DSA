class Solution:
    def totalNQueens(self, n: int) -> int:
        def issafe(row,col,grid):

            for i in range(row):
                if grid[i][col]:
                    return False
            
            i=row-1
            j=col-1
            while i>=0 and j>=0:
                if grid[i][j]:
                    return False
                i-=1
                j-=1

            i=row-1
            j=col+1
            while i>=0 and j<n:
                if grid[i][j]:
                    return False
                i-=1
                j+=1
            return True

        def recur(row,grid):
            nonlocal res
            if row==n:
                res+=1
                return
            else:
                for i in range(n):
                    if issafe(row,i,grid):
                        grid[row][i]=1
                        recur(row+1,grid)
                        grid[row][i]=0

        res=0
        grid=[[0]*n for _ in range(n)]
        recur(0,grid)
        return res
            
